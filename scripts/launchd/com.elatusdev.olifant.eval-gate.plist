<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.elatusdev.olifant.eval-gate</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>__HOME__/.olifant/eval-gate/nightly.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/olifant-eval-gate-nightly.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/olifant-eval-gate-nightly.log</string>
</dict>
</plist>
